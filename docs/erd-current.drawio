<mxfile host="app.diagrams.net" type="device">
  <diagram name="현재 도메인 연관관계 (main)" id="erd-current-main">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Entities (name only) ===== -->
        <mxCell id="seller" value="셀러&#10;(Seller)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="775" y="55" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="user" value="유저&#10;(User)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
