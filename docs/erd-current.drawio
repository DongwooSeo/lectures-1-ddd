        <mxCell id="e_cart_item" value="@OneToMany" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;" edge="1" parent="1" source="cart" target="cartitem">
