        </mxCell>
        <mxCell id="cart" value="장바구니&#10;(Cart)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1225" y="315" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="orderitem" value="주문 아이템&#10;(OrderItem)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="355" y="515" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="product" value="상품&#10;(Product)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="775" y="515" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="cartitem" value="카트 아이템&#10;(CartItem)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=15;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1225" y="515" width="230" height="110" as="geometry" />
        </mxCell>

        <!-- ===== Edges ===== -->
        <mxCell id="e_pay_order" value="@OneToOne" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=ERone;startFill=0;endArrow=ERone;endFill=0;" edge="1" parent="1" source="payment" target="order">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_order_item" value="@OneToMany" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;" edge="1" parent="1" source="order" target="orderitem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_item_product" value="@ManyToOne" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=ERmany;startFill=0;endArrow=ERone;endFill=0;" edge="1" parent="1" source="orderitem" target="product">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_product_seller" value="@ManyToOne ↔ @OneToMany" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=ERmany;startFill=0;endArrow=ERone;endFill=0;" edge="1" parent="1" source="product" target="seller">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_seller_user" value="@OneToOne" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=ERone;startFill=0;endArrow=ERone;endFill=0;" edge="1" parent="1" source="seller" target="user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_user_cart" value="@OneToOne" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=ERone;startFill=0;endArrow=ERone;endFill=0;" edge="1" parent="1" source="user" target="cart">
          <mxGeometry relative="1" as="geometry" />
